# Ejemplo de variables de entorno para uso local
# Copia este archivo a `.env.local` y rellena los valores.
# NO comites `.env.local` ni este archivo con valores reales.

# Variables públicas (se pueden exponer al cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Variables de servidor (NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY= # secret, sólo en servidor (Vercel/Secrets)
GOOGLE_GENERATIVE_AI_API_KEY=
CRON_SECRET= # cadena larga y aleatoria para proteger cron jobs

# Opcional: URL por defecto para avatares tristes (usada por el cron)
DEFAULT_SAD_AVATAR_URL=

# Notas:
# - Establece `NEXT_PUBLIC_*` tanto en local como en Vercel (Preview/Production) si
#   necesitas que el cliente pueda acceder a Supabase.
# - Establece `SUPABASE_SERVICE_ROLE_KEY` y `CRON_SECRET` sólo en el panel de
#   Vercel (Environment Variables) como variables protegidas.
# - Si el repo ya subió un `.env` con secretos, regenera/rota esas claves.